<UserControl x:Class="FarmBooks.UI.Views.ExpenseHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <TextBlock Text="Expense Details"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <TextBlock Text="Date"/>
        <DatePicker SelectedDate="{Binding ExpenseDate,
                                   UpdateSourceTrigger=PropertyChanged,
                                   ValidatesOnDataErrors=True}"
                    Margin="0,4,0,12"/>

        <TextBlock Text="Receipt #"/>
        <TextBox Text="{Binding DocumentNumber,
                        UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,4,0,12"/>

        <TextBlock Text="Business Name"/>
        <TextBox Text="{Binding BusinessName,
                        UpdateSourceTrigger=PropertyChanged,
                        ValidatesOnDataErrors=True}"
                 Margin="0,4,0,12"/>

        <TextBlock Text="Description"/>
        <TextBox Text="{Binding Description,
                        UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,4,0,12"/>

        <TextBlock Text="Total"/>
        <TextBox Text="{Binding Total,
                        UpdateSourceTrigger=PropertyChanged,
                        ValidatesOnDataErrors=True,
                        StringFormat=F2}"
                 Margin="0,4,0,12"/>
        <TextBlock Text="Notes"/>
        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="70"
                 Margin="0,4,0,12"/>
    </StackPanel>
</UserControl>