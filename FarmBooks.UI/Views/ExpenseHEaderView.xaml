<UserControl x:Class="FarmBooks.UI.Views.ExpenseHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <TextBlock Text="Expense Details"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <TextBlock Text="Expense Date" />
        <DatePicker SelectedDate="{Binding ExpenseDate}"
                    Margin="0,4,0,12" />

        <TextBlock Text="Paid Date" />
        <DatePicker SelectedDate="{Binding PaidDate}"
                    Margin="0,4,0,12" />

        <TextBlock Text="Source Type" />
        <ComboBox SelectedValue="{Binding SourceType}"
                  SelectedValuePath="Content"
                  Margin="0,4,0,12">
            <ComboBoxItem Content="Receipt" />
            <ComboBoxItem Content="Bank Statement" />
            <ComboBoxItem Content="Cash" />
            <ComboBoxItem Content="Manual" />
        </ComboBox>

        <TextBlock Text="Business Name" />
        <TextBox Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,4,0,12" />

        <TextBlock Text="Document Number" />
        <TextBox Text="{Binding DocumentNumber, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,4,0,12" />

        <TextBlock Text="Description" />
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,4,0,12" />

        <TextBlock Text="Total" />
        <TextBox Text="{Binding Total, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                 Margin="0,4,0,12" />

        <TextBlock Text="Status" />
        <TextBox Text="{Binding Status, Mode=OneWay}"
                 IsReadOnly="True"
                 Margin="0,4,0,12" />

        <TextBlock Text="Notes" />
        <TextBox Height="80"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Margin="0,4,0,12" />
    </StackPanel>
</UserControl>