<UserControl x:Class="FarmBooks.UI.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FarmBooks.UI.Views">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page title and primary action -->
        <Grid Grid.Row="0"
              Margin="0,0,0,14">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Transactions"
                       FontSize="26"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="New Transaction"
                    Width="120"
                    Height="34"
                    Command="{Binding NewTransactionCommand}"/>
        </Grid>

        <!-- Filter and search toolbar -->
        <Grid Grid.Row="1"
              Margin="0,0,0,12">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Show"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding TransactionList.FilterOptions}"
                      SelectedValue="{Binding TransactionList.SelectedFilter,
                                              Mode=TwoWay,
                                              UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Value"
                      DisplayMemberPath="Label"
                      Height="30"/>

            <TextBlock Grid.Column="3"
                       Text="Search"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox Grid.Column="4"
                     Text="{Binding TransactionList.SearchText,
                                    UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     VerticalContentAlignment="Center"
                     ToolTip="Search business name, receipt reference, or description"/>

            <TextBlock Grid.Column="6"
                       Text="{Binding TransactionList.VisibleTransactionCount,
                                      StringFormat={}{0} shown}"
                       VerticalAlignment="Center"
                       Foreground="#6B7280"/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="440"/>
            </Grid.ColumnDefinitions>

            <!-- Transaction list -->
            <Border Grid.Column="0"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Background="White">

                <views:TransactionListView DataContext="{Binding}"/>
            </Border>

            <!-- Transaction editor -->
            <views:TransactionEditorView Grid.Column="2"
                                         DataContext="{Binding TransactionEditor}"/>
        </Grid>
    </Grid>
</UserControl>