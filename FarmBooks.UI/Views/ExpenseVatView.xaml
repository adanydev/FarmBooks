<UserControl x:Class="FarmBooks.UI.Views.ExpenseVatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FarmBooks.Core.Models;assembly=FarmBooks.Core">

    <StackPanel>
        <TextBlock Text="VAT"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <TextBlock Text="Does this expense have VAT?"/>

        <ComboBox SelectedValue="{Binding VatApplicability,
                                  Mode=TwoWay,
                                  UpdateSourceTrigger=PropertyChanged}"
                  SelectedValuePath="Tag"
                  Margin="0,4,0,12">

            <ComboBoxItem Content="Not Sure"
                          Tag="{x:Static models:VatApplicability.NotSure}"/>

            <ComboBoxItem Content="Yes"
                          Tag="{x:Static models:VatApplicability.Yes}"/>

            <ComboBoxItem Content="No"
                          Tag="{x:Static models:VatApplicability.No}"/>
        </ComboBox>

        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility"
                            Value="Collapsed"/>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding VatApplicability}"
                                     Value="Yes">
                            <Setter Property="Visibility"
                                    Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="How was the VAT determined?"
                       Margin="0,0,0,6"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,12">

                <CheckBox Content="Entered manually"
                          IsChecked="{Binding IsVatEntered,
                                              Mode=TwoWay,
                                              UpdateSourceTrigger=PropertyChanged}"
                          Margin="0,0,20,0"/>

                <CheckBox Content="Calculated"
                          IsChecked="{Binding IsVatCalculated,
                                              Mode=TwoWay,
                                              UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="VATC"/>

                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding VATC,
                                    UpdateSourceTrigger=LostFocus,
                                    TargetNullValue='',
                                    StringFormat=F2}"/>

                        <Button Grid.Column="2"
                                Width="30"
                                Height="26"
                                Padding="0"
                                Content="🧮"
                                ToolTip="{Binding VatCalculationToolTip}"
                                Command="{Binding CalculateVatCCommand}"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="VATS"/>

                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding VATS,
                                    UpdateSourceTrigger=LostFocus,
                                    TargetNullValue='',
                                    StringFormat=F2}"/>

                        <Button Grid.Column="2"
                                Width="30"
                                Height="26"
                                Padding="0"
                                Content="🧮"
                                ToolTip="{Binding VatCalculationToolTip}"
                                Command="{Binding CalculateVatSCommand}"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <CheckBox Content="VATC and VATS are correct"
                      IsChecked="{Binding IsVatClassificationConfirmed,
                                          Mode=TwoWay,
                                          UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,0,0,4"/>
        </StackPanel>

        <TextBlock Margin="0,8,0,0"
                   Foreground="#6B7280"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text"
                            Value=""/>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding VatApplicability}"
                                     Value="No">
                            <Setter Property="Text"
                                    Value="No VAT applies. No further confirmation is required."/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding VatApplicability}"
                                     Value="NotSure">
                            <Setter Property="Text"
                                    Value="This expense will remain flagged until a VAT decision is made."/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </StackPanel>
</UserControl>