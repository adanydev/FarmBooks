<UserControl x:Class="FarmBooks.UI.Views.TransactionHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

       <StackPanel>
              <TextBlock Text="Transaction Details"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Margin="0,0,0,16"/>

              <TextBlock Text="Payment Date"/>
              <DatePicker SelectedDate="{Binding PaidDate,
                                   UpdateSourceTrigger=PropertyChanged}"
                          Margin="0,4,0,12"/>

              <TextBlock Text="Receipt Date"/>
              <DatePicker SelectedDate="{Binding TransactionDate,
                                   UpdateSourceTrigger=PropertyChanged,
                                   ValidatesOnDataErrors=True}"
                          Margin="0,4,0,12"/>

              <TextBlock Text="Receipt # / Reference"/>

              <ComboBox Text="{Binding DocumentNumber,
                         Mode=TwoWay,
                         UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Content"
                        IsEditable="True"
                        IsTextSearchEnabled="True"
                        StaysOpenOnEdit="True"
                        Margin="0,4,0,12">

                     <ComboBoxItem Content="Bank Statement"/>
                     <ComboBoxItem Content="Income"/>
                     <ComboBoxItem Content="EFT Bank Statement"/>
                     <ComboBoxItem Content="Wages and Allowances"/>
                     <ComboBoxItem Content="Record Entry - Cash Without Receipt"/>
              </ComboBox>

              <TextBlock Text="Business Name"/>
              <TextBox Text="{Binding BusinessName,
                                UpdateSourceTrigger=PropertyChanged,
                                ValidatesOnDataErrors=True}"
                       Margin="0,4,0,12"/>

              <TextBlock Text="Description"/>
              <TextBox Text="{Binding Description,
                                UpdateSourceTrigger=PropertyChanged}"
                       Margin="0,4,0,12"/>

              <TextBlock Text="Total"/>
              <TextBox Text="{Binding Total,
                                UpdateSourceTrigger=LostFocus,
                                ValidatesOnDataErrors=True,
                                StringFormat=F2}"
                       Margin="0,4,0,12"/>

              <TextBlock Text="Notes"/>
              <TextBox Text="{Binding Notes,
                                UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="70"
                       Margin="0,4,0,12"/>
       </StackPanel>
</UserControl>