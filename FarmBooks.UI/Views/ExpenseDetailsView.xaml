<UserControl x:Class="FarmBooks.UI.Views.ExpenseDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FarmBooks.UI.Views">

    <Border BorderBrush="#D1D5DB"
            BorderThickness="1"
            CornerRadius="4"
            Padding="16"
            Background="White">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <views:ExpenseHeaderView />

                <Separator Margin="0,8,0,8" />

                <views:ExpenseLineItemsView />
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>