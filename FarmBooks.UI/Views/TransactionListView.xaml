<UserControl x:Class="FarmBooks.UI.Views.TransactionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="StatusBadgeBorderStyle"
               TargetType="Border">
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="7,1"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FEF3C7"/>
            <Setter Property="BorderBrush" Value="#F59E0B"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="StatusBadgeTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="#92400E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <DataGrid ItemsSource="{Binding TransactionList.FilteredTransactions}"
              SelectedItem="{Binding SelectedTransaction}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True"
              SelectionMode="Single"
              SelectionUnit="FullRow"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              AlternatingRowBackground="#F9FAFB"
              BorderThickness="0">

        <DataGrid.ContextMenu>
            <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                               RelativeSource={RelativeSource Self}}">
                <MenuItem Header="Delete Transaction"
                          Command="{Binding DeleteTransactionCommand}"/>
            </ContextMenu>
        </DataGrid.ContextMenu>

        <DataGrid.Columns>
            <DataGridTextColumn Header="Date of Payment"
                                Binding="{Binding PaymentDate,
                                                  StringFormat={}{0:dd/MM/yyyy}}"
                                Width="105"/>

            <DataGridTextColumn Header="Code"
                                Binding="{Binding Code}"
                                Width="90"/>

            <DataGridTextColumn Header="Code Name"
                                Binding="{Binding CodeName}"
                                Width="130"/>

            <DataGridTextColumn Header="Receipt Date"
                                Binding="{Binding ReceiptDate,
                                                  StringFormat={}{0:dd/MM/yyyy}}"
                                Width="100"/>

            <DataGridTextColumn Header="Receipt No."
                                Binding="{Binding DocumentNumber}"
                                Width="110"/>

            <DataGridTextColumn Header="Company"
                                Binding="{Binding BusinessName}"
                                Width="140"/>

            <DataGridTextColumn Header="Description"
                                Binding="{Binding LineItemDescription}"
                                Width="*"/>

            <DataGridTextColumn Header="Amount"
                                Binding="{Binding LineItemTotal, StringFormat=C}"
                                Width="100">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Right"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,0,6,0"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTemplateColumn Header="VAT" Width="72">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Border ToolTip="{Binding VatIssuesToolTip}">
                            <Border.Style>
                                <Style TargetType="Border"
                                       BasedOn="{StaticResource StatusBadgeBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVatReady}" Value="True">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="{Binding VatStatusText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource StatusBadgeTextStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVatReady}" Value="True">
                                                <Setter Property="Foreground" Value="#166534"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Tax" Width="72">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Border ToolTip="{Binding TaxIssuesToolTip}">
                            <Border.Style>
                                <Style TargetType="Border"
                                       BasedOn="{StaticResource StatusBadgeBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTaxReady}" Value="True">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="{Binding TaxStatusText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource StatusBadgeTextStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTaxReady}" Value="True">
                                                <Setter Property="Foreground" Value="#166534"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
