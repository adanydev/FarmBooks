<Window x:Class="FarmBooks.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FarmBooks.UI.Views"
        Title="FarmBooks"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Border DockPanel.Dock="Left"
                Width="220"
                Background="#F3F4F6"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="12">
                <TextBlock Text="FarmBooks"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24" />

                <Button Content="Dashboard" Margin="0,0,0,8" Height="36" />
                <Button Content="Expenses" Margin="0,0,0,8" Height="36" />
                <Button Content="Bank" Margin="0,0,0,8" Height="36" />
                <Button Content="Accounting Codes" Margin="0,0,0,8" Height="36" />
                <Button Content="Settings" Margin="0,0,0,8" Height="36" />
            </StackPanel>
        </Border>

        <views:ExpensesView />
    </DockPanel>
</Window>