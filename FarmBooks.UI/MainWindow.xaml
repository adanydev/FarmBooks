<Window x:Class="FarmBooks.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FarmBooks"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

        <DockPanel>
                <Menu DockPanel.Dock="Top"
                      Height="30">
                        <MenuItem Header="_File">
                                <MenuItem Header="_New Expense"
                                          InputGestureText="Ctrl+N"
                                          Click="NewExpenseMenuItem_Click"/>

                                <Separator/>

                                <MenuItem Header="E_xit"
                                          Click="ExitMenuItem_Click"/>
                        </MenuItem>

                        <MenuItem Header="_Expenses"
                                  Click="ExpensesMenuItem_Click"/>

                        <MenuItem Header="_VAT Review"
                                  IsEnabled="False"/>

                        <MenuItem Header="_Accounting Codes"
                                  Click="AccountingCodesMenuItem_Click"/>

                        <MenuItem Header="_Reports"
                                  IsEnabled="False"/>

                        <MenuItem Header="_Settings"
                                  IsEnabled="False"/>
                </Menu>

                <ContentControl x:Name="MainContent"/>
        </DockPanel>
</Window>